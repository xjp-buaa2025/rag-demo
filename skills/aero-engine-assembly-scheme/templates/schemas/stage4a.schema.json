{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "stage4a.schema.json",
  "title": "Stage 4a — Assembly Procedures (Detailed Process)",
  "type": "object",
  "required": ["stage3_ref", "architecture_ref", "procedures", "topology"],
  "properties": {
    "stage3_ref": {
      "type": "string",
      "pattern": "^scheme-[0-9]{8}-[a-f0-9]{6}$"
    },
    "architecture_ref": {
      "type": "string",
      "pattern": "^A[0-9]+$",
      "description": "Selected architecture id from S3 candidate_architectures"
    },
    "procedures": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "seq_no", "depends_on", "parts_involved", "tooling", "spec_values"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^P[0-9]{2,}$",
            "description": "Procedure id, e.g. P01, P02"
          },
          "name": {"type": "string", "minLength": 2},
          "seq_no": {"type": "integer", "minimum": 1},
          "depends_on": {
            "type": "array",
            "items": {"type": "string"},
            "description": "List of procedure ids that must complete before this one"
          },
          "parts_involved": {
            "type": "array",
            "items": {"type": "string"},
            "description": "Part names or ids involved in this step"
          },
          "tooling": {
            "type": "array",
            "items": {"type": "string"},
            "description": "Tools and fixtures required"
          },
          "spec_values": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["param", "value"],
              "properties": {
                "param": {"type": "string", "minLength": 1},
                "value": {"type": "string", "minLength": 1},
                "standard": {"type": "string"}
              }
            }
          },
          "access_direction": {
            "type": "string",
            "enum": ["axial", "radial", "tangential", "other"]
          },
          "dfa_flag": {
            "type": "string",
            "enum": ["ok", "merge_candidate", "flip_required", "critical"]
          }
        }
      }
    },
    "topology": {
      "type": "object",
      "required": ["sequence", "method"],
      "properties": {
        "sequence": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Ordered procedure ids (topological sort result)"
        },
        "method": {
          "type": "string",
          "enum": ["DFA-heuristic", "KG-topo", "placeholder"]
        },
        "dfa_efficiency": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "critical_path": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "uncertainty": {
      "type": "string",
      "enum": ["高", "中", "低"]
    }
  }
}
